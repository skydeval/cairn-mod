{
  "lexicon": 1,
  "id": "tools.cairn.admin.listReports",
  "defs": {
    "main": {
      "type": "query",
      "description": "List reports with optional status and reporter filters. Paginated by opaque cursor.",
      "parameters": {
        "type": "params",
        "properties": {
          "status": {
            "type": "string",
            "knownValues": [
              "pending",
              "resolved"
            ]
          },
          "reportedBy": {
            "type": "string",
            "format": "did"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "reports"
          ],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "reports": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "tools.cairn.admin.defs#reportView"
              }
            }
          }
        }
      }
    }
  }
}
